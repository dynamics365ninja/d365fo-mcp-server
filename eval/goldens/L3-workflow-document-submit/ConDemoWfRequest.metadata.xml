				<Name>canSubmitToWorkflow</Name>
				<Source><![CDATA[
    /// <summary>
    /// Determines whether the record can be submitted to workflow.
    /// </summary>
    /// <param name = "_workflowType">The workflow type name.</param>
    /// <returns>true if the record can be submitted to workflow; otherwise, false.</returns>
    public boolean canSubmitToWorkflow(str _workflowType = '')
    {
        return super(_workflowType) && this.RequestId != '' && this.SubmittedToWorkflow == NoYes::No;
    }

]]></Source>
